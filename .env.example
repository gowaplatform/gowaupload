# Porta em que o app vai escutar
PORT=3000

# URL pública do app (usada nos links diretos dos arquivos)
# Exemplo EasyPanel: https://gowaupload.seudominio.com
APP_URL=http://localhost:3000

# Tamanho máximo do arquivo em MB
MAX_FILE_SIZE_MB=128

# Extensões permitidas (separadas por vírgula, sem ponto)
ALLOWED_EXTENSIONS=zip,mp4,ogg,aac,mp3,xls,xlsx,doc,docx,txt,jpg,jpeg,png,gif,csv

# Dias de retenção dos arquivos no servidor
RETENTION_DAYS=30

# Pasta de upload (relativa à raiz do app ou caminho absoluto)
UPLOAD_DIR=files
